    "autoprefixer": "^10.4.7",
    "classnames": "^2.3.2",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.0",
